# Riffle configuration (all variables optional — sensible defaults provided)
# Copy to `.env` and edit, or pass values as CLI flags.

# === Table location ===
# Local filesystem (default — no cloud setup required):
RIFFLE_TABLE_URI=./data/riffle-demo.delta

# Azure Data Lake Storage Gen2 (uncomment to use):
# RIFFLE_TABLE_URI=abfss://container@account.dfs.core.windows.net/path/to/table.delta
# RIFFLE_AZURE_AUTH=cli           # one of: cli | msi | key | env  (default: cli)
# AZURE_STORAGE_ACCOUNT_KEY=...   # only when RIFFLE_AZURE_AUTH=key

# AWS S3 (uncomment to use):
# RIFFLE_TABLE_URI=s3://my-bucket/path/to/table.delta
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_S3_ALLOW_UNSAFE_RENAME=true   # required by delta-rs on S3 without a lock provider

# Google Cloud Storage (uncomment to use):
# RIFFLE_TABLE_URI=gs://my-bucket/path/to/table.delta
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json

# === Dashboard ===
RIFFLE_BIND_ADDR=0.0.0.0:3000

# === Producer (demo data generator) ===
RIFFLE_PRODUCER_ENABLED=true
RIFFLE_BATCH_MIN_ROWS=1000
RIFFLE_BATCH_MAX_ROWS=500000
RIFFLE_WRITE_INTERVAL_SECS=8

# === Consumer (adaptive CDC reader) ===
RIFFLE_CONSUMER_ENABLED=true
RIFFLE_POLL_INTERVAL_SECS=3
RIFFLE_CHECKPOINT_FILE=riffle-checkpoint.json
RIFFLE_CHUNK_TARGET_ROWS=50000
RIFFLE_MERGE_THRESHOLD_ROWS=30000
RIFFLE_SPLIT_THRESHOLD_ROWS=100000
